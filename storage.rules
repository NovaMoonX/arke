rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /sessions/{sessionPin}/media/{fileName} {
      // Any authenticated user can read media files
      allow read: if request.auth != null;

      // Authenticated users can upload files within size limits by type
      allow write: if request.auth != null && (
        // Images up to 10MB
        (request.resource.contentType.matches('image/.*')
          && request.resource.size <= 10 * 1024 * 1024)
        ||
        // Videos up to 50MB
        (request.resource.contentType.matches('video/.*')
          && request.resource.size <= 50 * 1024 * 1024)
        ||
        // Audio up to 50MB
        (request.resource.contentType.matches('audio/.*')
          && request.resource.size <= 50 * 1024 * 1024)
        ||
        // Documents, archives, and text files up to 10MB
        (request.resource.size <= 10 * 1024 * 1024
          && (
            // PDF
            request.resource.contentType == 'application/pdf'
            ||
            // Microsoft Office documents
            request.resource.contentType.matches('application/vnd\\.ms-.*')
            ||
            request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\..*')
            ||
            // Archives
            request.resource.contentType == 'application/zip'
            || request.resource.contentType == 'application/x-zip-compressed'
            || request.resource.contentType == 'application/gzip'
            || request.resource.contentType == 'application/x-tar'
            || request.resource.contentType == 'application/x-7z-compressed'
            || request.resource.contentType == 'application/x-rar-compressed'
            ||
            // Text and data
            request.resource.contentType.matches('text/.*')
            || request.resource.contentType == 'application/json'
            || request.resource.contentType == 'application/xml'
          ))
      );

      allow delete: if request.auth != null;
    }

    // Cache file uploads — same size/type limits as session media
    match /sessions/__cache__/{userId}/{fileName} {
      allow read: if request.auth != null;

      allow write: if request.auth != null
        && request.auth.uid == userId
        && (
          (request.resource.contentType.matches('image/.*')
            && request.resource.size <= 10 * 1024 * 1024)
          ||
          (request.resource.contentType.matches('video/.*')
            && request.resource.size <= 50 * 1024 * 1024)
          ||
          (request.resource.contentType.matches('audio/.*')
            && request.resource.size <= 50 * 1024 * 1024)
          ||
          (request.resource.size <= 10 * 1024 * 1024
            && (
              request.resource.contentType == 'application/pdf'
              || request.resource.contentType.matches('application/vnd\\.ms-.*')
              || request.resource.contentType.matches('application/vnd\\.openxmlformats-officedocument\\..*')
              || request.resource.contentType == 'application/zip'
              || request.resource.contentType == 'application/x-zip-compressed'
              || request.resource.contentType == 'application/gzip'
              || request.resource.contentType == 'application/x-tar'
              || request.resource.contentType == 'application/x-7z-compressed'
              || request.resource.contentType == 'application/x-rar-compressed'
              || request.resource.contentType.matches('text/.*')
              || request.resource.contentType == 'application/json'
              || request.resource.contentType == 'application/xml'
            ))
        );

      allow delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}
